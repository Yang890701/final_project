# 複製成 .env 並填值（.env 已被 .gitignore 忽略，勿入庫）
# 不填 DATABASE_URL → 自動 fallback 用 db/fixtures.json（可零基礎設施 demo）
DATABASE_URL=
# 不填 GEMINI_API_KEY → 偵測走模型+規則 fallback（仍可 demo）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === 上線安全（顧問建議）===
# 允許的前端來源（逗號分隔）；上線務必改成你的前端網域，勿用 *
ALLOWED_ORIGINS=http://localhost:5173
# /api/detect 每 IP 限流：每 WINDOW 秒最多 LIMIT 次
DETECT_RATE_LIMIT=30
DETECT_RATE_WINDOW=60
# Gemini 月度呼叫上限（成本護欄），超過自動降級不打 Gemini
GEMINI_MONTHLY_CAP=1000
